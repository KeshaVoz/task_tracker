DB_HOST=db
DB_PORT=5432
DB_NAME=task_manager_db
DB_USER=postgres
DB_PASSWORD=your_secure_db_password_here
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_db_password_here@db:5432/task_manager_db

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_URL=redis://:your_redis_password_here@redis:6379/0

JWT_SECRET=your_jwt_secret_key_minimum_32_characters_here
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@tasktracker.local

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password_here
CELERY_BROKER_URL=amqp://guest:your_rabbitmq_password_here@rabbitmq:5672//

KAFKA_URL=kafka:29092

SUMMARY_DB_HOST=db-summarization
SUMMARY_DB_PORT=5432
SUMMARY_DB_NAME=summarization_db
SUMMARY_DB_USER=postgres
SUMMARY_DB_PASSWORD=your_summary_db_password_here
SUMMARY_DATABASE_URL=postgresql+asyncpg://postgres:your_summary_db_password_here@db-summarization:5432/summarization_db

LLM_CREDENTIALS=your_llm_api_credentials_here
LLM_MODEL=GigaChat

ALLOWED_ORIGINS=your_origins